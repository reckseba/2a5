    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "next": "16.1.6",
    "pg": "^8.19.0",
    "prisma": "^7.4.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
